# Build-time only — prefix VITE_ is required for Vite.
# Production: your Render (or other) backend URL, no trailing slash.
# Example: https://da-backend-xxxx.onrender.com
VITE_API_BASE_URL=http://127.0.0.1:5000

# Minutes after last agent ingest; "Plugin Active" if data received within this window (default 5).
# VITE_AGENT_ONLINE_MINUTES=5
